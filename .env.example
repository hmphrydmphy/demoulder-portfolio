# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Template for environment variables
#
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to GitHub — it contains your secrets.
# This .env.example file is safe to commit because it has no real values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Site URL ──────────────────────────────────────────────────────────────────
# Your live domain. Used for generating absolute URLs and Open Graph metadata.
# During development this is usually http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://humphreypimentel.com

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
#
# NEXT_PUBLIC_ prefix means these values are visible in the browser.
# The anon key is safe to expose — it is restricted by Row Level Security (RLS).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# The service role key has FULL database access — never expose this in the browser.
# Only use it in server-side code (API routes, server components).
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# ── Resend (email notifications) ──────────────────────────────────────────────
# Found in: resend.com → API Keys
# Used to send you an email whenever someone submits the contact form.
RESEND_API_KEY=re_your-resend-api-key-here

# The email address where contact form notifications will be sent.
# This is your personal email inbox.
CONTACT_FORM_TO_EMAIL=your-email@example.com
